<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryColor">#00838F</Color>
    <Color x:Key="PrimaryLightColor">#00ACC1</Color>
    <Color x:Key="TextPrimaryColor">#1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#555555</Color>
    <Color x:Key="TextTertiaryColor">#888888</Color>
    <Color x:Key="TextAccentColor">#00838F</Color>
    <Color x:Key="BorderColor">#D1D1D1</Color>
    <Color x:Key="ControlBackgroundColor">#F5F5F5</Color>
    <Color x:Key="ControlHoverColor">#E8E8E8</Color>
    <Color x:Key="DangerColor">#E53935</Color>
    <Color x:Key="DropdownBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ShadowColor">#888888</Color>
    <Color x:Key="SuccessColor">#43A047</Color>
    <Color x:Key="WarningColor">#FFA000</Color>
    <Color x:Key="AccentColor">#00838F</Color>
    <Color x:Key="StatusActiveColor">#43A047</Color>
    <Color x:Key="StatusInactiveColor">#CCCCCC</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextAccentBrush" Color="{StaticResource TextAccentColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource ControlBackgroundColor}" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="{StaticResource ControlHoverColor}" />
    <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="{StaticResource DropdownBackgroundColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="StatusActiveBrush" Color="{StaticResource StatusActiveColor}" />
    <SolidColorBrush x:Key="StatusInactiveBrush" Color="{StaticResource StatusInactiveColor}" />

    <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFF5F5F5" Offset="0" />
        <GradientStop Color="#FFFFFFFF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TitleBarBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E5E0E0E0" Offset="0" />
        <GradientStop Color="#E5ECECEC" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BorderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#33DDDDDD" Offset="0.0" />
        <GradientStop Color="#99008191" Offset="0.3" />
        <GradientStop Color="#BB00838F" Offset="0.5" />
        <GradientStop Color="#99008191" Offset="0.7" />
        <GradientStop Color="#33DDDDDD" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFEEEEEE" Offset="0.0" />
        <GradientStop Color="#FFE8E8E8" Offset="0.3" />
        <GradientStop Color="#FFE0E0E0" Offset="0.7" />
        <GradientStop Color="#FFDCDCDC" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>
