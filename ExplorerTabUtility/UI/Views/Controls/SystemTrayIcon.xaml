<UserControl x:Class="ExplorerTabUtility.UI.Views.Controls.SystemTrayIcon"
             xmlns:managers="clr-namespace:ExplorerTabUtility.Managers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             x:Name="ThisObject">

    <tb:TaskbarIcon x:Name="TrayIcon"
                    Visibility="Visible"
                    DataContext="{Binding ElementName=ThisObject}"
                    TrayMouseDoubleClick="OnNotifyIconDoubleClick">

        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu>
                <MenuItem Name="KeyboardHookMenu"
                          IsCheckable="False"
                          IsChecked="{Binding Source={x:Static managers:SettingsManager.IsKeyboardHookActive}, Mode=OneTime}"
                          ToolTip="{Binding Source={StaticResource Loc}, Path=[KeyboardShortcut]}">
                    <MenuItem.Header>
                        <Grid>
                            <CheckBox Command="{Binding RelativeSource={RelativeSource AncestorType=MenuItem}, Path=Command}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=MenuItem}, Path=CommandParameter}"
                                      Background="Transparent" Opacity="0" Margin="-35,0,0,0"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                            <TextBlock Background="Transparent" IsHitTestVisible="False" VerticalAlignment="Center"
                                       Text="{Binding Source={StaticResource Loc}, Path=[KeyboardShortcut]}" />
                        </Grid>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE8AC;" FontSize="14" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Name="MouseHookMenu"
                          IsCheckable="False"
                          IsChecked="{Binding Source={x:Static managers:SettingsManager.IsMouseHookActive}, Mode=OneTime}"
                          ToolTip="{Binding Source={StaticResource Loc}, Path=[MouseShortcut]}">
                    <MenuItem.Header>
                        <Grid>
                            <CheckBox Command="{Binding RelativeSource={RelativeSource AncestorType=MenuItem}, Path=Command}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=MenuItem}, Path=CommandParameter}"
                                      Background="Transparent" Opacity="0" Margin="-35,0,0,0"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                            <TextBlock Background="Transparent" IsHitTestVisible="False" VerticalAlignment="Center"
                                       Text="{Binding Source={StaticResource Loc}, Path=[MouseShortcut]}" />
                        </Grid>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE962;" FontSize="14" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Name="WindowHook"
                          StaysOpenOnClick="True" IsCheckable="True"
                          IsChecked="{Binding Source={x:Static managers:SettingsManager.IsWindowHookActive}, Mode=OneTime}"
                          Header="{Binding Source={StaticResource Loc}, Path=[WindowIntercept]}"
                          ToolTip="{Binding Source={StaticResource Loc}, Path=[StatusWindowHook]}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE8A7;" FontSize="14" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Name="ReuseTabs"
                          StaysOpenOnClick="True" IsCheckable="True"
                          IsChecked="{Binding Source={x:Static managers:SettingsManager.ReuseTabs}, Mode=OneTime}"
                          Header="{Binding Source={StaticResource Loc}, Path=[TabReuse]}"
                          ToolTip="{Binding Source={StaticResource Loc}, Path=[TabReuse]}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE8EE;" FontSize="14" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem Name="AddToStartup"
                          StaysOpenOnClick="True" IsCheckable="True"
                          IsChecked="{Binding Source={x:Static managers:RegistryManager.IsStartupEnabled}, Mode=OneTime}"
                          Header="{Binding Source={StaticResource Loc}, Path=[AddToStartup]}"
                          ToolTip="{Binding Source={StaticResource Loc}, Path=[AddToStartup]}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE7F4;" FontSize="14" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem x:Name="OpenSettings"
                          Header="{Binding Source={StaticResource Loc}, Path=[Settings]}"
                          ToolTip="{Binding Source={StaticResource Loc}, Path=[Settings]}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE713;" FontSize="14" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem x:Name="ExitApplication"
                          Header="{Binding Source={StaticResource Loc}, Path=[Exit]}"
                          ToolTip="{Binding Source={StaticResource Loc}, Path=[Exit]}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE7E8;" FontSize="14" Foreground="{StaticResource DangerBrush}" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>

</UserControl>
