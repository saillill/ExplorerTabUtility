<UserControl x:Class="ExplorerTabUtility.UI.Views.HotKeyProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:ExplorerTabUtility.UI.Views.Controls"
             mc:Ignorable="d"
             TextBlock.Foreground="{DynamicResource TextPrimaryBrush}"
             TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
             d:DesignHeight="125" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border Style="{StaticResource ProfileCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Main Row -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Enabled Toggle -->
                <ToggleButton x:Name="CbEnabled" Grid.Column="0" Style="{StaticResource ToggleButtonStyle}"
                              VerticalAlignment="Stretch"
                              ToolTip="{Binding Source={StaticResource Loc}, Path=[ProfileEnabledTooltip]}" />

                <!-- Name -->
                <TextBox x:Name="TxtName" Grid.Column="1" Tag="Name" Style="{StaticResource CustomTextBoxStyle}"
                         ToolTip="{Binding Source={StaticResource Loc}, Path=[ProfileNameTooltip]}" />

                <!-- Hotkeys -->
                <TextBox x:Name="TxtHotKeys" Grid.Column="3" Tag="Hotkeys" Style="{StaticResource CustomTextBoxStyle}"
                         ToolTip="{Binding Source={StaticResource Loc}, Path=[HotKeysTooltip]}" />

                <!-- Scope -->
                <ComboBox x:Name="CbScope" Grid.Column="5" Style="{StaticResource CustomComboBoxStyle}" SelectedValuePath="Value"
                         ToolTip="{Binding Source={StaticResource Loc}, Path=[ScopeTooltip]}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Action -->
                <ComboBox x:Name="CbAction" Grid.Column="6" Style="{StaticResource CustomComboBoxStyle}" Width="150" SelectedValuePath="Value"
                         ToolTip="{Binding Source={StaticResource Loc}, Path=[ActionTooltip]}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Expander button -->
                <ToggleButton x:Name="ExpanderToggle" Grid.Column="7" Margin="4, 0" Style="{StaticResource ToggleButtonArrowStyle}"
                              ToolTip="{Binding Source={StaticResource Loc}, Path=[ExpanderTooltip]}" />

                <!-- Delete Button -->
                <Button x:Name="BtnDelete" Grid.Column="8" ToolTip="{Binding Source={StaticResource Loc}, Path=[DeleteProfileTooltip]}">
                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="16" Height="16" />
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Expanded Details -->
            <Grid x:Name="ExpandedPanel" Grid.Row="1" Margin="0, 6, 0, 0"
                  Visibility="{Binding ElementName=ExpanderToggle, Path=IsChecked, Mode=TwoWay, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Path -->
                <TextBox Grid.Column="0" x:Name="TxtPath" Tag="Location" Style="{StaticResource CustomTextBoxStyle}"
                         ContextMenu="{StaticResource TextBoxCustomContextMenu}"
                         ToolTip="{Binding Source={StaticResource Loc}, Path=[PathTooltip]}" />

                <!-- Delay -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6"
                            ToolTip="{Binding Source={StaticResource Loc}, Path=[DelayTooltip]}">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,6,0"
                               Text="{Binding Source={StaticResource Loc}, Path=[Delay]}" />

                    <controls:NumericInputControl x:Name="NDelay" Margin="0" MinWidth="100"
                                                  Minimum="0" Maximum="10000" Step="100" Suffix="ms"
                                                  StringFormat="{}{0:N0}" />
                </StackPanel>

                <!-- Handled -->
                <ToggleButton Grid.Column="2" x:Name="CbHandled" Style="{StaticResource ToggleButtonStyle}" Margin="5,0"
                              Content="{Binding Source={StaticResource Loc}, Path=[Handled]}"
                              ToolTip="{Binding Source={StaticResource Loc}, Path=[HandledTooltip]}" />

                <!-- Open as Tab -->
                <ToggleButton Grid.Column="3" x:Name="CbOpenAsTab" Style="{StaticResource ToggleButtonStyle}" Margin="5,0"
                              Content="{Binding Source={StaticResource Loc}, Path=[Tab]}"
                              ToolTip="{Binding Source={StaticResource Loc}, Path=[TabTooltip]}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
