<Window x:Class="ExplorerTabUtility.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ExplorerTabUtility.UI.Views"
        xmlns:managers="clr-namespace:ExplorerTabUtility.Managers"
        Title="{Binding Source={StaticResource Loc}, Path=[AppTitleWithDesc]}"
        Width="850" Height="600"
        MinWidth="700" MinHeight="175"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        TextBlock.Foreground="{DynamicResource TextPrimaryBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">

    <Border Background="{DynamicResource BackgroundGradientBrush}"
            BorderBrush="{DynamicResource BorderGradientBrush}"
            CornerRadius="5"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="{DynamicResource TitleBarBrush}" CornerRadius="4, 4, 0, 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Menu Button -->
                    <ToggleButton x:Name="DrawerButton" Grid.Column="0" Style="{StaticResource ToggleButtonIconStyle}" Margin="6,0,0,0"
                                  Content="&#x2630;" Focusable="False"
                                  ToolTip="{Binding Source={StaticResource Loc}, Path=[MenuOpen]}" />

                    <!-- Window Title -->
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Text="{Binding Source={StaticResource Loc}, Path=[AppTitle]}" />

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="MinimizeButton" Style="{StaticResource IconButtonStyle}" Content="&#x2212;" Focusable="False" />
                        <Button x:Name="MaximizeButton" Focusable="False">
                            <Button.Style>
                                <Style BasedOn="{StaticResource IconButtonStyle}" TargetType="Button">
                                    <Setter Property="Content" Value="&#x2610;" />
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding WindowState, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                                            Value="Maximized">
                                            <Setter Property="Content" Value="&#x2750;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="CloseButton" Style="{StaticResource IconButtonStyle}" Content="&#x2715;" Focusable="False"
                                Margin="0,0,8,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <!-- Custom Drawer Implementation -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Menu Drawer -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource CardGradientBrush}"
                            BorderBrush="{DynamicResource BorderGradientBrush}"
                            BorderThickness="0,0,1,0"
                            CornerRadius="0,0,0,4"
                            Width="0">
                        <DockPanel>
                            <ListBox x:Name="NavigationList" DockPanel.Dock="Top" SelectedIndex="0"
                                     Style="{StaticResource NavigationListBoxStyle}">
                                <ListBox.Resources>
                                    <Storyboard x:Key="CloseDrawerStoryboard">
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="DrawerButton"
                                                                        Storyboard.TargetProperty="IsChecked">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False" />
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </ListBox.Resources>
                                <ListBox.Triggers>
                                    <EventTrigger RoutedEvent="ListBox.MouseLeftButtonDown">
                                        <BeginStoryboard Storyboard="{StaticResource CloseDrawerStoryboard}"/>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="ListBox.PreviewMouseDoubleClick">
                                        <BeginStoryboard Storyboard="{StaticResource CloseDrawerStoryboard}"/>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="ListBox.KeyDown">
                                        <BeginStoryboard Storyboard="{StaticResource CloseDrawerStoryboard}"/>
                                    </EventTrigger>
                                </ListBox.Triggers>
                                <ListBoxItem ToolTip="{Binding Source={StaticResource Loc}, Path=[MenuShortcuts]}">
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding Source={StaticResource Loc}, Path=[MenuShortcuts]}" />
                                </ListBoxItem>
                                <ListBoxItem ToolTip="{Binding Source={StaticResource Loc}, Path=[MenuPreferences]}">
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding Source={StaticResource Loc}, Path=[MenuPreferences]}" />
                                </ListBoxItem>
                                <ListBoxItem ToolTip="{Binding Source={StaticResource Loc}, Path=[MenuAbout]}">
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding Source={StaticResource Loc}, Path=[MenuAbout]}" />
                                </ListBoxItem>
                            </ListBox>
                        </DockPanel>

                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.3" Color="{DynamicResource ShadowColor}" />
                        </Border.Effect>

                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=DrawerButton}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" BeginTime="0:0:0.1" />
                                                    <DoubleAnimation Storyboard.TargetProperty="Width" To="170" Duration="0:0:0.3">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                                    <DoubleAnimation Storyboard.TargetProperty="Width" To="0" Duration="0:0:0.3">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Main Content -->
                    <Grid Grid.Column="1">
                        <TabControl Style="{StaticResource CustomTabControlStyle}"
                                    SelectedIndex="{Binding SelectedIndex, ElementName=NavigationList}">
                            <TabControl.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.2" Color="{DynamicResource ShadowColor}" />
                            </TabControl.Effect>
                            <!-- Shortcuts Tab -->
                            <TabItem Header="{Binding Source={StaticResource Loc}, Path=[TabShortcuts]}" Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Toolbar -->
                                    <DockPanel Grid.Row="0" Margin="16,8" LastChildFill="False">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                            <Button x:Name="BtnNewProfile" Style="{StaticResource FlatButtonStyle}"
                                                    Content="{Binding Source={StaticResource Loc}, Path=[BtnNewProfile]}"
                                                    ToolTip="{Binding Source={StaticResource Loc}, Path=[BtnNewProfile]}" />
                                            <Button x:Name="BtnImport" Style="{StaticResource FlatButtonStyle}"
                                                    Content="{Binding Source={StaticResource Loc}, Path=[BtnImport]}"
                                                    ToolTip="{Binding Source={StaticResource Loc}, Path=[BtnImport]}" />
                                            <Button x:Name="BtnExport" Style="{StaticResource FlatButtonStyle}"
                                                    Content="{Binding Source={StaticResource Loc}, Path=[BtnExport]}"
                                                    ToolTip="{Binding Source={StaticResource Loc}, Path=[BtnExport]}" />
                                            <Button x:Name="BtnSave" Style="{StaticResource FlatButtonStyle}"
                                                    Content="{Binding Source={StaticResource Loc}, Path=[BtnSave]}"
                                                    ToolTip="{Binding Source={StaticResource Loc}, Path=[BtnSave]}" />
                                        </StackPanel>

                                        <CheckBox DockPanel.Dock="Right" x:Name="CbAutoSaveProfiles"
                                                  Style="{StaticResource CustomCheckBoxStyle}"
                                                  Content="{Binding Source={StaticResource Loc}, Path=[AutoSave]}"
                                                  ToolTip="{Binding Source={StaticResource Loc}, Path=[AutoSaveTooltip]}" />
                                    </DockPanel>

                                    <!-- Profiles Panel -->
                                    <ScrollViewer Grid.Row="1" Margin="16,8,4,4"
                                                  VerticalScrollBarVisibility="Visible"
                                                  Style="{StaticResource CustomScrollViewerStyle}">
                                        <StackPanel x:Name="ProfilesPanel" />
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>

                            <!-- Preferences Tab -->
                            <TabItem Header="{Binding Source={StaticResource Loc}, Path=[TabPreferences]}" Visibility="Collapsed">
                                <StackPanel Margin="16, 8">
                                    <GroupBox Style="{StaticResource CustomGroupBoxStyle}"
                                              Header="{Binding Source={StaticResource Loc}, Path=[GroupAppSettings]}">
                                        <StackPanel Margin="8">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding Source={StaticResource Loc}, Path=[Theme]}" />
                                                <ComboBox x:Name="CbTheme" Style="{StaticResource CustomComboBoxStyle}" Width="120"
                                                          SelectedValuePath="Value" DisplayMemberPath="Display"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding Source={StaticResource Loc}, Path=[Language]}" />
                                                <ComboBox x:Name="CbLanguage" Style="{StaticResource CustomComboBoxStyle}" Width="100"
                                                          SelectedValuePath="Value" DisplayMemberPath="Display"/>
                                            </StackPanel>
                                            <CheckBox x:Name="CbThemeIssue" Style="{StaticResource CustomCheckBoxStyle}"
                                                      Content="{Binding Source={StaticResource Loc}, Path=[ThemeCompatibilityMode]}"
                                                      ToolTip="{Binding Source={StaticResource Loc}, Path=[ThemeCompatibilityTooltip]}" />
                                            <CheckBox x:Name="CbSaveClosedHistory" Style="{StaticResource CustomCheckBoxStyle}"
                                                      Content="{Binding Source={StaticResource Loc}, Path=[SaveClosedHistory]}"
                                                      ToolTip="{Binding Source={StaticResource Loc}, Path=[SaveClosedHistoryTooltip]}" />
                                            <CheckBox x:Name="CbRestorePreviousWindows" Style="{StaticResource CustomCheckBoxStyle}"
                                                      Content="{Binding Source={StaticResource Loc}, Path=[RestorePreviousWindows]}"
                                                      ToolTip="{Binding Source={StaticResource Loc}, Path=[RestorePreviousWindowsTooltip]}" />
                                            <CheckBox x:Name="CbHideTrayIcon" Style="{StaticResource CustomCheckBoxStyle}"
                                                      Content="{Binding Source={StaticResource Loc}, Path=[HideTrayIcon]}"
                                                      ToolTip="{Binding Source={StaticResource Loc}, Path=[HideTrayIconTooltip]}" />
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </TabItem>

                            <!-- About Tab -->
                            <TabItem Header="{Binding Source={StaticResource Loc}, Path=[TabAbout]}" Visibility="Collapsed">
                                <local:AboutView />
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="{DynamicResource ControlBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,4,4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,4">
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <Ellipse Width="12" Height="12" Margin="0,0,6,0" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource StatusInactiveBrush}" />
                                        <Setter Property="Stroke" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=(managers:SettingsManager.IsWindowHookActive)}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource StatusActiveBrush}" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Color="{DynamicResource StatusActiveColor}" Opacity="0.7" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Text="{Binding Source={StaticResource Loc}, Path=[StatusWindowHook]}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <Ellipse Width="12" Height="12" Margin="0,0,6,0" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource StatusInactiveBrush}" />
                                        <Setter Property="Stroke" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=(managers:SettingsManager.ReuseTabs)}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource StatusActiveBrush}" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Color="{DynamicResource StatusActiveColor}" Opacity="0.7" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Text="{Binding Source={StaticResource Loc}, Path=[StatusReuseTabs]}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <Ellipse Width="12" Height="12" Margin="0,0,6,0" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource StatusInactiveBrush}" />
                                        <Setter Property="Stroke" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=(managers:SettingsManager.IsKeyboardHookActive)}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource StatusActiveBrush}" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Color="{DynamicResource StatusActiveColor}" Opacity="0.7" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Text="{Binding Source={StaticResource Loc}, Path=[StatusKeyboardHook]}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <Ellipse Width="12" Height="12" Margin="0,0,6,0" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource StatusInactiveBrush}" />
                                        <Setter Property="Stroke" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=(managers:SettingsManager.IsMouseHookActive)}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource StatusActiveBrush}" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Color="{DynamicResource StatusActiveColor}" Opacity="0.7" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Text="{Binding Source={StaticResource Loc}, Path=[StatusMouseHook]}" />
                        </StackPanel>
                    </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
